{
  "name": "portfolio",
  "version": "1.0.0",
  "main": "index.html",
  "scripts": {
  "postcss": "postcss src/main.css -o public/main.min.css",
  "minify:css": "cleancss -o public/main.min.css public/main.min.css",
  "minify:html": "html-minifier src/index.html -o public/index.html --collapse-whitespace --remove-comments --minify-css true --minify-js true",
  "minify:js": "terser src/script.js -o public/script.min.js -c -m",
  "build": "npm run postcss && npm run minify:css && npm run minify:html && npm run minify:js"
},
  "author": "Luan Alves",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "html-minifier": "^4.0.0",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "postcss-preset-env": "^10.0.9",
    "terser": "^5.36.0"
  }
}
